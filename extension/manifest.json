{
  "manifest_version": 3,
  "name": "YouTube ABSA Analyzer",
  "version": "1.0",

  "permissions": ["tabs", "activeTab"],

  "host_permissions": [
    "https://www.youtube.com/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
