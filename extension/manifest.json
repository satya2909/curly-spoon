{
  "manifest_version": 3,
  "name": "YouTube ABSA Analyzer",
  "version": "1.0",

  "permissions": ["tabs", "activeTab"],

  "host_permissions": ["https://www.youtube.com/*"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
